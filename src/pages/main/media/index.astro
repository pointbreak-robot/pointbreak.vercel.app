---
import Layout from "../../../layouts/Layout.astro";
---

<Layout title="Point Break - Media">
    <main>
        <section class="hero">
            <div class="hero-content">
                <h1 class="media">MEDIA</h1>
            </div>
        </section>
        <section class="szn1">
            <h2>2026-27 SEASON</h2>
            <p>Coming Soon!</p>
            <div class="szn-content"></div>
        </section>
    </main>
</Layout>

<style>
    main {
        padding-top: 0px;
        margin: 0;
        gap: 1rem;
        position: relative;
    }

    h2 {
        text-align: center;
    }

    .hero {
        width: 100%;
        height: 100vh;
        background-color: var(--rgb-bg-from);
        background-size: cover;
        background-position: center;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        box-sizing: border-box;
        padding-top: 95px;
    }

    .hero-content {
        position: relative;
        z-index: 1;
        text-align: center;
        width: 100%;
    }

    .media {
        font-size: clamp(2rem, 6vw, 5rem);
        white-space: nowrap;
        font-weight: 900;
        color: white;
        text-transform: uppercase;
        margin: 0;
        letter-spacing: 2px;
    }

    .szn1 {
        background: var(--rgb-code-bg);
        padding: clamp(1.5rem, 4vw, 4rem) clamp(1rem, 3vw, 2rem);
        margin: 0 auto;
        width: 95%;
        border: 2px solid var(--rgb-accent-from);
        border-radius: 16px;
        scroll-margin-top: 105px;
        box-sizing: border-box;
        text-align: center;
        position: relative;
        z-index: 1;
    }
</style>

