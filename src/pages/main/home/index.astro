---
import Layout from "../../../layouts/Layout.astro"
---../../../scripts/waves.js

<Layout title="Point Break">
    <main>
        <section class="hero">
            <div class="hero-content">
                <h1 class="point"><span class="accent">POINT</span> BREAK 🏄‍♂️</h1>
            </div>
        </section>
        <section id="about" class="fade-in">
            <h1>About Us</h1>
            <p>Point Break Robotics is an independent high school VEX V5 robotics team based in Fremont, California. We are a passionate group of student engineers, programmers, and designers dedicated to pushing the boundaries of competitive robotics. Competing in the VEX V5 Robotics Competition, we combine technical expertise with creative problem-solving to design, build, and program robots capable of taking on the world's best teams. Our mission is to foster a love for STEM, develop real-world engineering skills, and represent our community on the competitive stage.</p>
            <div class="team-photo-box">
                <!-- replace -->
            </div>
        </section>
        <hr class="section-divider">
        <section id="track" class="fade-in">
            <h1>Track Records</h1>
            <div class="season-card1">
                <div class="szn-label">Override Season</div>
                <div class="szn-content">
                    <div class="szn-record">
                        <span class="szn-sublabel">RECORD</span>
                        <p class="record">0-0-0</p>
                    </div>
                    <div class="szn-divider"></div>
                    <div class="szn-awards">
                        <span class="szn-sublabel">AWARDS</span>
                        <p></p>
                        <p></p>
                        <p></p>
                    </div>
                </div>
            </div>
        </section>
        <hr class="section-divider">
        <section id="team" class="fade-in">
            <h1>Meet The Team</h1>
            <div class="team-grid">
                <div class="member">
                    <div class="photo-circle"></div>
                    <h3>SRIMAN SREEPATHI</h3>
                    <li>Programming Team</li>
                    <li>Hardware Team</li>
                    <li>Notebook Lead</li>
                </div>
                <div class="member">
                    <div class="photo-circle"></div>
                    <h3>PRANAV PYDI</h3>
                    <li>Hardware & CAD Team</li>
                    <li>Programming Team</li>
                    <li>Notebook Assist</li>
                </div>
                <div class="member">
                    <div class="photo-circle"></div>
                    <h3>TWANSHU KHATRI</h3>
                    <li>Driver</li>
                    <li>Hardware Team</li>
                    <li>Notebook Assist</li>
                </div>
                <div class="member">
                    <div class="photo-circle"></div>
                    <h3>JUSTIN GAO</h3>
                    <li>Hardware Team</li>
                    <li>Notebook Team</li>
                </div>
                <div class="member">
                    <div class="photo-circle"></div>
                    <h3>ABHI GHOSH</h3>
                    <li>Hardware Team</li>
                    <li>Notebook Assist</li>
                    <li>Media</li>
                </div>
                <div class="member">
                    <div class="photo-circle"></div>
                    <h3>DEV BHATT</h3>
                    <li>Programming Team</li>
                    <li>Notebook Assist</li>
                    <li>Hardware Team</li>
                </div>
                <div class="member last">
                    <div class="photo-circle"></div>
                    <h3>MATTHEW HO</h3>
                    <li>Hardware Team</li>
                    <li>Programming Team</li>
                    <li>Notebook Assist</li>
                </div>
            </div>
        </section>
    </main>
</Layout>

<style>
    main {
        padding-top: 0;
        margin: 0;
        gap: 10rem;
        position: relative;
    }

    .hero {
        width: 100%;
        height: 100vh;
        background-color: var(--rgb-bg-from);
        background-size: cover;
        background-position: center;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        box-sizing: border-box;
        padding-top: 95px;
    }

    .hero-content {
        position: relative;
        z-index: 1;
        text-align: center;
        width: 100%;
    }

    .point {
        font-size: clamp(2rem, 7vw, 5rem);
        white-space: nowrap;
        font-weight: 900;
        color: white;
        text-transform: uppercase;
        margin: 0;
        letter-spacing: 2px;
    }

    #about, #team {
        background: var(--rgb-code-bg);
        padding: clamp(1.5rem, 4vw, 4rem) clamp(1rem, 3vw, 2rem);
        margin: 0 auto;
        width: 95%;
        border: 2px solid var(--rgb-accent-from);
        border-radius: 16px;
        scroll-margin-top: 105px;
        box-sizing: border-box;
        position: relative;
        z-index: 1;
    }

    #about p, #team p {
        margin-top: 1.5rem;
        text-align: left;
        line-height: 2;
        max-width: 600px;
    }

    #about p {
        padding-left: 2.5rem;
        font-size: 20px;
    }

    #track {
        padding: 0rem 0;
        display: flex;
        flex-direction: column;
        gap: 2rem;
        position: relative;
        z-index: 1;
    }

    #track h1 {
        font-size: 60px;
        padding-left: 2rem;
        margin: 0;
    }

    .season-card1 {
        width: 100%;
        box-sizing: border-box;
        border-left: 6px solid var(--rgb-accent-to);
        border-right: 6px solid var(--rgb-accent-to);
        padding: 3rem 4rem;
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    .szn-label {
        font-size: 1.5rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 4px;
        color: #38b6ff;
    }

    .section-divider {
        border: none;
        border-top: 5px solid var(--rgb-accent-from);
        width: 90%;
        margin: 0 auto;
        position: relative;
        z-index: 1;
    }

    .szn-content {
        display: flex;
        flex-direction: row;
        align-items: flex-start;
        gap: 0;
        width: 100%;
    }

    .szn-record {
        display: flex;
        flex-direction: column;
        align-items: center;
        flex: 1;
        gap: 0.5rem;
    }

    .szn-sublabel {
        font-size: 1.5rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 3px;
        color: rgba(255, 255, 255, 0.5);
    }

    .record {
        font-size: 4rem;
        font-weight: 700;
        padding-top: 3rem;
        color: #38b6ff;
        margin: 0;
        letter-spacing: 2px;
    }

    .szn-divider {
        width: 1px;
        height: 150px;
        background: rgba(255, 255, 255, 0.2);
        margin: 0 2rem;
    }

    .szn-awards {
        display: flex;
        flex-direction: column;
        align-items: center;
        flex: 1;
        gap: 0.4rem;
    }

    .szn-awards p {
        font-size: 1.5rem;
        color: #38b6ff;
        margin: 0;
        line-height: 1.6;
    }

    .team-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
        margin-top: 2rem;
        justify-items: center;
    }

    .team-grid .last {
        grid-column: 2;
    }

    .member {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 0.75rem;
    }

    .photo-circle {
        width: 250px;
        height: 250px;
        border-radius: 50%;
        border: 3px solid var(--rgb-accent-from);
        overflow: hidden;
        background: var(--rgb-bg-from);
    }

    .photo-circle img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .member h3 {
        margin: 0;
        font-size: 1.5rem;
        color: white;
    }

    .member li {
        margin: 0;
        font-size: 1.1rem;
        color: white;
        line-height: 1.4;
    }

    .fade-in {
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 0.8s ease, transform 0.8s ease;
    }

    .fade-in.visible {
        opacity: 1;
        transform: translateY(0);
    }

    @media (max-width: 768px) {
        .team-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 480px) {
        .team-grid {
            grid-template-columns: 1fr;
        }
    }

    .accent {
        color: #38b6ff;
    }
</style>

