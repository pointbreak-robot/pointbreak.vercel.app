---
import Layout from "../../../layouts/Layout.astro";
---

<Layout title="Circuit Surfers - Donate">
    <main>
        <section class="hero">
            <div class="hero-content">
                <h1 class="hero-donate">DONATE</h1>
            </div>
        </section>
        <section id="donate">
            <h1>Support Our Team ❤️</h1><br>
            <p class="subtitle">Circuit Surfers is a student-run team operating independently without school funding. Every donation directly supports our team by covering competition registration fees, robot parts, and travel expenses. Your contribution helps us continue competing, learning, and representing our team on the robotics stage. No amount is too small — we appreciate every bit of support from our community!</p><br>

            <h2>How Your Money is Used 🤔</h2>
            <p class="subtitle">Here is how your money will be used to keep our team competing and growing:</p>

            <div class="cards">
                <div class="card">
                    <div class="icon">🏆</div>
                    <h3>Competition Registration</h3>
                    <p>Entry fees for league tournaments, regional championships, and state competitions.</p>
                </div>
                <div class="card">
                    <div class="icon">🤖</div>
                    <h3>Robot Parts</h3>
                    <p>VEX V5 motors, sensors, aluminum structure, and electronic components to build and maintain our competition robot.</p>
                </div>
                <div class="card">
                    <div class="icon">🛠️</div>
                    <h3>Tools & Equipment</h3>
                    <p>Specialized tools, safety equipment, and workspace improvements.</p>
                </div>
                <div class="card">
                    <div class="icon">✈️</div>
                    <h3>Travel Expenses</h3>
                    <p>Travel expenses for out-of-state tournaments.</p>
                </div>
            </div>

            <div class="page">
                <h2>Make a Donation 🏦</h2>
                <p class="subtitle">Your donation helps Circuit Surfers continue competing and inspiring the next generation of engineers — every contribution counts!</p>
                <div class="btn-wrapper">
                    <a class="donate-btn">
                        <div class="btn-logo">
                            <img src="/assets/img/icons/stripe.png" alt="stripe-logo" />
                        </div>
                        Donate via Stripe
                    </a>
                </div>
            </div>
        </section>
    </main>
</Layout>

<style>
    main {
        padding-top: 0px;
        margin: 0;
    }

    .hero {
        width: 100%;
        height: 100vh;
        background-color: var(--rgb-bg-from);
        background-size: cover;
        background-position: center;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        box-sizing: border-box;
        padding-top: 95px;
    }

    .hero-donate {
        position: relative;
        z-index: 1;
        text-align: center;
        width: 100%;
        font-size: clamp(2rem, 6vw, 5rem);
        white-space: nowrap;
        font-weight: 900;
        color: white;
        text-transform: uppercase;
        margin: 0;
        letter-spacing: 2px;
    }

    #donate {
        padding: 4rem 2rem;
        max-width: 1600px;
        margin: 2rem auto;
        text-align: center;
    }

    #donate h1 {
        font-size: clamp(2.5rem, 5vw, 4rem);
    }

    #donate h2 {
        font-size: clamp(2rem, 4vw, 3rem);
    }

    .subtitle {
        color: white;
        max-width: 900px;
        margin: 1rem auto 3rem auto;
        line-height: 1.8;
        font-size: 1.2rem;
    }

    h2 {
        margin-top: 3rem;
    }

    .cards {
        display: flex;
        flex-wrap: wrap;
        gap: 1.5rem;
        justify-content: center;
        margin-top: 2rem;
    }

    .card {
        background-color: var(--rgb-code-bg);
        border: 1px solid var(--rgb-accent-from);
        border-radius: 16px;
        padding: 2rem;
        width: 280px;
        text-align: center;
        transition: transform 0.3s ease;
    }

    .card:hover {
        transform: translateY(-5px);
    }

    .icon {
        font-size: 1.5rem;
        background-color: var(--rgb-accent-to);
        border-radius: 50%;
        width: 60px;
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1rem auto;
    }

    .card h3 {
        font-size: 1rem;
        margin: 0.5rem 0;
    }

    .page {
        margin: 4rem auto 0 auto;
        border: 2px solid var(--rgb-accent-from);
        background: var(--rgb-code-bg);
        border-radius: 16px;
        width: 100%;
        max-width: 1600px;
        padding: 2rem;
        box-sizing: border-box;
    }

    .btn-wrapper {
        display: flex;
        justify-content: center;
        margin-top: 2rem;
    }

    .donate-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        background: linear-gradient(135deg, var(--rgb-accent-from), var(--rgb-accent-to));
        color: white;
        text-decoration: none;
        font-weight: 700;
        font-size: 1.4rem;
        padding: 1.5rem 5rem;
        border-radius: 12px;
        border: none;
        box-shadow: 0 4px 15px rgba(56, 182, 255, 0.4);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        width: 600px;
    }

    .btn-logo {
        width: 64px;
        height: 64px;
        border-radius: 50cqmin;
        overflow: hidden;
        background: white;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .btn-logo img {
        width: 100%;
        height: 100%;
        object-fit: contain;
    }

    .donate-btn:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 25px rgba(56, 182, 255, 0.6);
        color: white;
        cursor: pointer;
    }
</style>