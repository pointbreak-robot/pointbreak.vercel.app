---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 - Page Not Found">
    <main>
        <section id="not-found">
            <h1 class="error-code">404</h1>
            <h2 class="subtitle">Page Not Found</h2>
            <p class="description">Looks like this page got lost at sea. Let's get you back on course!</p>
            <div class="btn-wrapper">
                <a href="/" class="back-btn">🌊 Back to Home</a>
            </div>
        </section>
    </main>
</Layout>

<style>
    main {
        padding-top: 95px;
        margin: 0;
    }

    #not-found {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 4rem 2rem;
        min-height: 70vh;
    }

    /* 404 number bounces in */
    .error-code {
        font-size: clamp(6rem, 20vw, 12rem);
        color: var(--rgb-accent-from);
        margin: 0;
        line-height: 1;
        animation: bounceIn 0.8s ease forwards;
    }

    /* subtitle slides up */
    .subtitle {
        font-size: clamp(1.5rem, 4vw, 2.5rem);
        margin: 1rem 0;
        opacity: 0;
        animation: slideUp 0.6s ease 0.4s forwards;
    }

    /* description fades in */
    .description {
        color: var(--rgb-text-gray);
        max-width: 400px;
        line-height: 1.8;
        margin-bottom: 2rem;
        opacity: 0;
        animation: fadeIn 0.6s ease 0.7s forwards;
    }

    /* button fades in last */
    .btn-wrapper {
        display: flex;
        justify-content: center;
        margin-top: 1rem;
        opacity: 0;
        animation: fadeIn 0.6s ease 1s forwards;
    }

    .back-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, var(--rgb-accent-from), var(--rgb-accent-to));
        color: white;
        text-decoration: none;
        font-weight: 700;
        font-size: 1.2rem;
        padding: 1rem 2.5rem;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(56, 182, 255, 0.4);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .back-btn:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 25px rgba(56, 182, 255, 0.6);
        color: white;
    }

    /* 404 pulses after appearing */
    @keyframes bounceIn {
        0% { transform: scale(0); opacity: 0; }
        60% { transform: scale(1.2); opacity: 1; }
        80% { transform: scale(0.9); }
        100% { transform: scale(1); opacity: 1; }
    }

    @keyframes slideUp {
        0% { transform: translateY(30px); opacity: 0; }
        100% { transform: translateY(0); opacity: 1; }
    }

    @keyframes fadeIn {
        0% { opacity: 0; }
        100% { opacity: 1; }
    }

    /* 404 floats up and down continuously */
    .error-code {
        animation: bounceIn 0.8s ease forwards, float 3s ease-in-out 1s infinite;
    }

    @keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-20px); }
    }
</style>