---
---

<nav class="navbar">
    <div class="container">

        <div class="logo-socials">
            <a href={`${import.meta.env.BASE_URL}`} class="logo">
                <img src={`${import.meta.env.BASE_URL}assets/img/icons/logo.png`} alt="circuit-surfers-logo">
            </a>

            <!-- socials -->
            <div class="socials">
                <a href="https://instagram.com/circuitsurfersrobotics" target="_blank" aria-label="Instagram">
                    <img src={`${import.meta.env.BASE_URL}assets/img/icons/instagram.png`} alt="Instagram" />
                </a>
                <a href="https://youtube.com/@circuitsurfersrobotics" target="_blank" aria-label="YouTube">
                    <img src={`${import.meta.env.BASE_URL}assets/img/icons/youtube.png`} alt="YouTube" />
                </a>
                <a href="https://github.com/circuitsurfers-robotics" target="_blank" aria-label="GitHub">
                    <img src={`${import.meta.env.BASE_URL}assets/img/icons/github.svg`} alt="GitHub" />
                </a>
                <a href="https://robotevents.com/teams/V5RC/93332A" target="_blank" aria-label="VEX">
                    <img src={`${import.meta.env.BASE_URL}assets/img/icons/vex.png`} alt="VEX"/>
                </a>
            </div>
        </div>

        <!-- navbar -->
        <ul class="nav-links">
            <li><a href={`${import.meta.env.BASE_URL}main/home#about`}>About</a></li>
            <li><a href={`${import.meta.env.BASE_URL}main/home#team`}>Team</a></li>
            <li><a href={`${import.meta.env.BASE_URL}main/media`}>Media</a></li>
            <li><a href={`${import.meta.env.BASE_URL}main/donate`}>Donate</a></li>
        </ul>
    </div>
</nav>

<style>
    .navbar {
        height: 95px;
        padding: 15px 40px;
        display: flex;
        align-items: center;
        overflow: visible;
        background: linear-gradient(135deg, #0a1628, #38b6ff, #1a6fd4, #0a1628);
        background-size: 400% 400%;
        position: fixed;
        top: 0;
        width: 100%;
        z-index: 999;
        box-sizing: border-box;
    }

    .container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
    }

    .logo-socials {
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 5px;
    }

    .logo img {
        width: 120px;
        height: auto;
        cursor: pointer;
    }

    .socials {
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 12px;
    }

    .socials a {
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.2s ease, opacity 0.2s ease;
    }

    .socials a:hover {
        transform: scale(1.15);
        opacity: 0.85;
        z-index: 10;
        position: relative;
    }

    .socials img {
        width: 28px;
        height: 28px;
        object-fit: contain;
    }

    .socials a[aria-label="VEX"] {
        width: 48px;
        height: 48px;
        overflow: hidden;
    }

    .socials a[aria-label="VEX"] img {
        width: 55px;
        height: 55px;
        object-fit: contain;
        margin-left: 1px;
    }

    .nav-links {
        display: flex;
        list-style: none;
        gap: 30px;
        margin: 0;
        padding: 0;
    }

    .nav-links a {
        color: white;
        text-decoration: none;
        font-weight: 900;
        font-size: 16px;
        letter-spacing: 1px;
        text-transform: uppercase;
        transition: color 0.3s ease;
    }

    .nav-links a:hover {
        color: #38b6ff;
    }
</style>