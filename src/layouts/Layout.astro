---
interface Props {
    title: string;
}

const { title } = Astro.props;
import Footer from "../components/Footer.astro"
import Header from "../components/Header.astro";
import { ClientRouter } from 'astro:transitions';
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="keywords" content="point, break, pointbreak, vex, robotics">
        <meta name="author" content="Point Break">
        <meta name="viewport" content="width=device-width">
        <link rel="icon" href="/favicon.ico" sizes="any" />
        <link rel="icon" type="image/ico" href="/favicon.ico" transition:persist/>
        <meta name="generator" content={Astro.generator} />
        <link rel="preload" href={`${import.meta.env.BASE_URL}assets/fonts/Orbitron/Orbitron-VariableFont_wght.ttf`} as="font" type="font/ttf" crossorigin>
        <link rel="preload" href={`${import.meta.env.BASE_URL}assets/fonts/Montserrat/Montserrat-VariableFont_wght.ttf`} as="font" type="font/ttf" crossorigin>
        <script src="/assets/js/konami_code.js" is:inline></script>
        <ClientRouter />
        <title>{title}</title>
        <slot name="head"/>
    </head>
    <body>
        <Header />
        <slot />
        <Footer />
    </body>
</html>

<style is:global>

    * {
        box-sizing: border-box;
    }

    @font-face {
        font-family: 'Orbitron';
        src: url("/assets/fonts/Orbitron/Orbitron-VariableFont_wght.ttf");
        font-display: swap;
    }
    @font-face {
        font-family: 'Montserrat';
        src: url("/assets/fonts/Montserrat/Montserrat-VariableFont_wght.ttf");
        font-display: swap;
    }

    :root {
        font-size: clamp(12px, 2.5vw, 20px);
        display: flex;
        justify-content: center;

        --rgb-bg-from: #0a1628;
        --rgb-bg-to: #050d1a;
        --rgb-text: #ffffff;
        --rgb-accent-from: #38b6ff;
        --rgb-accent-to: #1a6fd4;
        --rgb-code-bg: #0d1f3c;
        --rgb-text-gray: #7aafd4;
        --rgb-text-warning: #56d4ff;
        background-color: var(--rgb-bg-from);
        font-family: 'Montserrat', system-ui;
        color: var(--rgb-text);
        line-height: 1.15rem;
    }

    html {
        min-height: 100vh;
        scroll-behavior: smooth;
        scrollbar-gutter: stable;
    }

    section {
        margin: 0;
        padding: 0;
        width: 100vw;
        overflow-x: hidden;
        background-color: transparent;
    }

    .wave-bg {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 0;
        pointer-events: none;
    }

    .wave-bg svg {
        width: 100%;
        height: 100%;
    }

    .fade-in {
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.6s ease, transform 0.6s ease;
    }

    .fade-in.visible {
        opacity: 1;
        transform: translateY(0);
    }

    body {
        margin: 0;
        padding: 0;
        width: 100vw;
        min-height: 100vh;
        position: relative;
        background: var(--rgb-bg-from);
    }

    body > header,
    body > footer,
    body > nav {
        margin: 0;
    }

    main {
        margin: 0;
        display: flex;
        flex-direction: column;
    }

    h1 {
        font-size: 2.5rem;
        line-height: 3rem;
        text-align: center;
        margin: 0 1rem;
        font-family: 'Orbitron', monospace, system-ui;
    }
    h2 {
        font-size: 2rem;
        line-height: 2rem;
        font-family: 'Orbitron', monospace, system-ui;
    }
    h3 {
        font-size: 1.5rem;
        line-height: 1.5rem;
        font-family: 'Orbitron', monospace, system-ui;
    }

</style>

<script>
    import { addWaves } from '../scripts/waves.js'
    import { initFadeIn } from '../scripts/fadeIn.js'

    function init() {
        addWaves();
        initFadeIn();
    }

    document.addEventListener('astro:page-load', init);
    document.addEventListener('DOMContentLoaded', init);
</script>